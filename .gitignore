# Gradle / Kotlin
.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar
local.properties

# Downloaded ML models (fetched into assets at build time, not committed)
**/assets/*.task

# Android
*.apk
*.aab
*.keystore
*.jks
# ...except the committed debug keystore: it must be versioned so every CI build shares one
# signing key, otherwise updates won't install over each other. Debug-only; not a secret.
!app-android/debug.keystore
.cxx/
captures/

# Secrets — BLE keys, signing config, API tokens
.env
*.env
secrets.properties

# IDE / OS junk
.idea/
*.iml
.DS_Store
Thumbs.db
